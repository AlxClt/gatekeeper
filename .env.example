# LLM backend is set by which compose files you run, not here:
#   online (default): docker compose up
#   local:            docker compose -f docker-compose.yml -f docker-compose.local-llm.yml --profile local-llm up
# Uncomment to force a value regardless of the compose invocation:
# LLM_BACKEND=local

# Prompt
PROMPT_NAME= default-9b #default-3b

# Disable reasoning/"thinking" output for hybrid reasoning models (e.g. qwen3, deepseek-r1) so the
# raw response is just the bare "0"/"1" the verifier expects. Ignored by non-reasoning models.
# gpt-oss models require "low"/"medium"/"high" instead of a boolean — see llm_adaptater.py warning.
LLM_THINK=false

# In case of server side error or malformed LLM response
LLM_RETRY_CALLS=3

# Local LLM via Ollama
LOCAL_LLM_MODEL=llama3.2 #gemma2:2b-instruct-q8_0 #llama3.2 #qwen3:0.6b

# Online LLM (OpenAI-compatible — covers OpenAI, Azure OpenAI, Groq, etc.)
ONLINE_LLM_API_KEY=your-secret-key-here
ONLINE_LLM_BASE_URL= #https://api.openai.com/v1
ONLINE_LLM_MODEL=gemma2:9b #gemma2:9b #llama3.2 #gpt-4o-mini
# ollama-server wrapper has Ollama-style cold starts, not a real always-warm API —
# warm it up at startup and give it enough time to load the model.
ONLINE_LLM_WARMUP=true
ONLINE_LLM_TIMEOUT=300

# Database (prod only — docker-compose.prod.yml)
POSTGRES_PASSWORD=changeme

HF_TOKEN=changeme
